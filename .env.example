# Meta WhatsApp Business API
META_API_TOKEN=tu_token_largo_aqui
PHONE_NUMBER_ID=tu_phone_number_id_aqui
WABA_ID=tu_waba_id_aqui

# Webhook (debe coincidir con el configurado en Meta Developers)
WEBHOOK_VERIFY_TOKEN=elige_un_token_unico_y_dificil_de_adivinar
# App Secret de tu app de Meta (Configuracion > Basica). Se usa para validar
# la firma X-Hub-Signature-256 de cada POST al webhook.
META_APP_SECRET=tu_app_secret_de_meta

# Anthropic (Claude)
ANTHROPIC_API_KEY=tu_api_key_de_anthropic

# Base de datos
DATABASE_URL=postgresql://usuario:password@host:puerto/basededatos

# Panel de control (/panel, /control, /reporte) - elige un token largo y unico
CONTROL_TOKEN=elige_un_token_largo_y_dificil_de_adivinar

# Numero de WhatsApp de Lili (solo digitos, con codigo de pais, sin +)
LILI_NUMERO=573000000000

# Notificaciones por Telegram a Lili
TELEGRAM_TOKEN=tu_token_de_bot_de_telegram
TELEGRAM_CHAT_ID=tu_chat_id_de_telegram

# Server
PORT=3000
NODE_ENV=production
